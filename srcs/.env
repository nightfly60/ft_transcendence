# MYSQL INFOS
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=transcendence
MYSQL_USER=niroprime
MYSQL_PASSWORD=niroprime

#NGINX_PORT
NGINX_PORT=443

#LOGIN AND DOMAINE NAME
LOGIN=edurance

# ========================================
# Application Configuration
# ========================================
NODE_ENV=development
NODE_VERSION=24.11.1-alpine   # correspond à la version Node que tu utilises dans Dockerfile

# ========================================
# Port Configuration
# ========================================
APP_PORT=3000       # Port de ton app Node.js
VITE_PORT=5173      # Port de dev Angular
DEBUG_PORT=9229     # Port debug Node.js
PROD_PORT=8080      # Port prod si tu exposes Node.js directement

# ========================================
# Security Configuration
# ========================================
ALLOWED_ORIGINS=https://chess42.fr

# ========================================
# Production Deployment (Docker registry)
# ========================================
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=ton-username
DOCKER_REPOSITORY=transcendence-nodejs
